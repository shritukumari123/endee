# Endee Vector Database
ENDEE_BASE_URL=http://localhost:8080
ENDEE_AUTH_TOKEN=

# Groq Free API
OPENAI_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# Embeddings (local — zero cost, no API key needed)
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Endee Index Names
MEMORIES_INDEX=engram_memories
ENTITIES_INDEX=engram_entities
INSIGHTS_INDEX=engram_insights
TIMELINE_INDEX=engram_timeline

# Ingestion Settings
CHUNK_SIZE=400
CHUNK_OVERLAP=50
DEDUP_THRESHOLD=0.85

# App
APP_ENV=development
LOG_LEVEL=INFO